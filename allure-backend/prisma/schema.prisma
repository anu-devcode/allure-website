generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  phone     String?  @unique
  city      String?
  name      String?
  role      Role     @default(ADMIN)
  failedLoginAttempts Int @default(0)
  lockoutUntil DateTime?
  orders    Order[]
  reviews   Review[]
  wishlist  Wishlist?
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

enum AuthDomain {
  CUSTOMER
  ADMIN
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  productType String   @default("Other")
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id           String       @id @default(uuid())
  name         String
  slug         String       @unique
  description  String?
  price        Float
  salePrice    Float?
  compareAtPrice Float?
  sku          String?
  stockQuantity Int        @default(0)
  isBulkAvailable Boolean  @default(false)
  bulkMinQty   Int?
  bulkPrice    Float?
  category     Category     @relation(fields: [categoryId], references: [id])
  categoryId   String
  availability Availability @default(IN_STORE)
  origin       String?      // e.g., Turkey, Shein
  badge        String?
  productType  String?
  details      Json?
  images       String[]     // Array of image URLs
  reviews      Review[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  OrderItems   OrderItem[]
  WishlistItems WishlistItem[]
}

enum Availability {
  IN_STORE
  PRE_ORDER
  SOLD_OUT
}

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique // e.g., ORD-1001
  customer      User?       @relation(fields: [customerId], references: [id])
  customerId    String?
  customerName  String
  customerPhone String
  city          String      @default("Addis Ababa")
  total         Float
  status        OrderStatus @default(NEW)
  paymentStatus PaymentStatus @default(PENDING)
  paymentReference String?
  paymentProof  String?
  items         OrderItem[]
  reviews       Review[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum OrderStatus {
  NEW
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

model OrderItem {
  id        String  @id @default(uuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  productName String
  productImage String?
  variantSelection Json?
  quantity  Int
  price     Float   // Price at time of purchase
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique // e.g. "hero_title", "social_telegram"
  value String
}

model CustomRequest {
  id            String        @id @default(uuid())
  customerName  String
  customerPhone String
  itemLink      String?
  description   String
  imageUrls     String[]
  status        RequestStatus @default(PENDING)
  adminNotes    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Review {
  id            String   @id @default(uuid())
  customer      User?    @relation(fields: [customerId], references: [id])
  customerId    String?
  customerName  String
  customerEmail String?
  product       Product? @relation(fields: [productId], references: [id])
  productId     String?
  productName   String?
  order         Order?   @relation(fields: [orderId], references: [id])
  orderId       String?
  rating        Int
  comment       String
  isApproved    Boolean  @default(false)
  isVerifiedPurchase Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId, isApproved])
  @@index([customerId])
  @@index([orderId])
  @@unique([customerId, productId, orderId])
}

model ContactMessage {
  id          String                @id @default(uuid())
  name        String
  contact     String
  message     String
  status      ContactMessageStatus  @default(NEW)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model Wishlist {
  id         String         @id @default(uuid())
  guestId    String?        @unique
  customer   User?          @relation(fields: [customerId], references: [id])
  customerId String?        @unique
  items      WishlistItem[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  wishlistId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  createdAt  DateTime @default(now())

  @@unique([wishlistId, productId])
}

model RefreshToken {
  id          String     @id @default(uuid())
  tokenHash   String     @unique
  domain      AuthDomain
  expiresAt   DateTime
  revokedAt   DateTime?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  createdAt   DateTime   @default(now())

  @@index([userId, domain])
  @@index([expiresAt])
}

model PasswordResetToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

enum RequestStatus {
  PENDING
  QUOTED
  CONVERTED
  REJECTED
}

enum ContactMessageStatus {
  NEW
  RESOLVED
}
